{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014Dc3oLJV3rSfh7DannGKmU","type":"tool_result","content":"1\timport matter from \"gray-matter\";\n2\t\n3\timport { normalizeInlineMaps } from \"../schema/load\";\n4\timport type { NormalizedRecord, Schema } from \"../schema/types\";\n5\t\n6\texport function renderArtifact(\n7\t  template: string,\n8\t  values: NormalizedRecord,\n9\t  bodySections?: Record<string, string>,\n10\t): string {\n11\t  const parsed = matter(normalizeInlineMaps(template));\n12\t  // Templater scripts are for manual creation inside Obsidian only — leaked\n13\t  // into a rendered artifact they execute on file creation and prompt the user.\n14\t  const noTemplater = parsed.content.replace(/<!--\\s*<%\\*[\\s\\S]*?-->\\n*/g, \"\");\n15\t  const stripped = stripGuidanceForFilled(noTemplater, bodySections);\n16\t  const withLists = renderEachBlocks(stripped, values);\n17\t  const body = withLists.replace(/{{([A-Za-z0-9_]+)}}/g, (_placeholder: string, name: string) => {\n18\t    const section = bodySections?.[name];\n19\t    if (section !== undefined) {\n20\t      return section;\n21\t    }\n22\t    if (name === \"date\") {\n23\t      const updated = values.updated;\n24\t      return typeof updated === \"string\" ? updated : \"\";\n25\t    }\n26\t    const value = values[name];\n27\t    if (Array.isArray(value)) {\n28\t      return value.join(\", \");\n29\t    }\n30\t    if (value === undefined) {\n31\t      return \"\";\n32\t    }\n33\t    return String(value);\n34\t  });\n35\t\n36\t  return `${matter.stringify(body.trimStart(), values)}\\n`;\n37\t}\n38\t\n39\t/**\n40\t * Remove the authoring-guidance blockquote that follows a `{{placeholder}}`\n41\t * line for every placeholder that received body content — the guidance is\n42\t * for an author filling the section in, not for a filled artifact.\n43\t */\n44\tfunction stripGuidanceForFilled(body: string, bodySections?: Record<string, string>): string {\n45\t  if (bodySections === undefined) {\n46\t    return body;\n47\t  }\n48\t  let result = body;\n49\t  for (const name of Object.keys(bodySections)) {\n50\t    const guidanceRe = new RegExp(`({{${name}}})\\\\n\\\\n(?:>.*\\\\n?)+`);\n51\t    result = result.replace(guidanceRe, \"$1\\n\");\n52\t  }\n53\t  return result;\n54\t}\n55\t\n56\t/**\n57\t * Expand `{{#each field}}…{{else}}…{{/each}}` blocks: the each branch repeats\n58\t * per list item with `{{this}}` substituted; the else branch renders when the\n59\t * field is missing, not a list, or empty. Runs before the plain-placeholder\n60\t * pass so `{{this}}` never leaks into it.\n61\t */\n62\tfunction renderEachBlocks(body: string, values: NormalizedRecord): string {\n63\t  const blockRe = /{{#each ([A-Za-z0-9_]+)}}([\\s\\S]*?)(?:{{else}}([\\s\\S]*?))?{{\\/each}}/g;\n64\t  return body.replace(blockRe, (_block: string, name: string, item: string, elseBranch: string | undefined) => {\n65\t    const value = values[name];\n66\t    if (Array.isArray(value) && value.length > 0) {\n67\t      return value.map((entry) => item.replace(/{{this}}/g, String(entry))).join(\"\");\n68\t    }\n69\t    return elseBranch ?? \"\";\n70\t  });\n71\t}\n72\t\n73\t/**\n74\t * Canonical frontmatter order: schema declaration order first (id leads),\n75\t * then any unknown fields in their original relative order.\n76\t */\n77\texport function orderBySchema(schema: Schema, record: NormalizedRecord): NormalizedRecord {\n78\t  const schemaNames = schema.fields.map((field) => field.name);\n79\t  const known = new Set(schemaNames);\n80\t  const ordered: NormalizedRecord = {};\n81\t  for (const name of schemaNames) {\n82\t    if (record[name] !== undefined) ordered[name] = record[name];\n83\t  }\n84\t  for (const name of Object.keys(record)) {\n85\t    if (!known.has(name)) ordered[name] = record[name];\n86\t  }\n87\t  return ordered;\n88\t}\n89\t\n90\texport function applyDefaults(schema: Schema, template: string, input: Record<string, unknown>): NormalizedRecord {\n91\t  const values: NormalizedRecord = { ...input };\n92\t  const today = new Date().toISOString().slice(0, 10);\n93\t\n94\t  const templateDefaults = readTemplateDefaults(template);\n95\t\n96\t  for (const field of schema.fields) {\n97\t    if (values[field.name] !== undefined) {\n98\t      continue;\n99\t    }\n100\t    const templateDefault = templateDefaults[field.name];\n101\t    if (templateDefault !== undefined) {\n102\t      values[field.name] = templateDefault;\n103\t    } else if (field.name === \"created\" || field.name === \"updated\" || field.name === \"session_date\") {\n104\t      values[field.name] = today;\n105\t    } else if (field.type === \"list\" || field.type === \"link_list\") {\n106\t      values[field.name] = [];\n107\t    }\n108\t  }\n109\t\n110\t  return values;\n111\t}\n112\t\n113\tfunction readTemplateDefaults(template: string): Record<string, unknown> {\n114\t  const parsed = matter(normalizeInlineMaps(template));\n115\t  const rawSchema = parsed.data.schema;\n116\t  if (!isRecord(rawSchema)) {\n117\t    return {};\n118\t  }\n119\t  const defaults: Record<string, unknown> = {};\n120\t  for (const [fieldName, rawField] of Object.entries(rawSchema)) {\n121\t    if (isRecord(rawField) && rawField.default !== undefined) {\n122\t      defaults[fieldName] = rawField.default;\n123\t    }\n124\t  }\n125\t  return defaults;\n126\t}\n127\t\n128\tfunction isRecord(value: unknown): value is Record<string, unknown> {\n129\t  return typeof value === \"object\" && value !== null && !Array.isArray(value);\n130\t}\n131\t"}]},"parent_tool_use_id":null,"session_id":"5a24f960-2834-4b0d-82fe-20b82465aea9","uuid":"dd2da644-7b5a-4cff-b052-97d52acebd2e","timestamp":"2026-06-23T16:47:23.155Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/tothemoon/Dev/code-forge/wiki/src/artifacts/render.ts","content":"import matter from \"gray-matter\";\n\nimport { normalizeInlineMaps } from \"../schema/load\";\nimport type { NormalizedRecord, Schema } from \"../schema/types\";\n\nexport function renderArtifact(\n  template: string,\n  values: NormalizedRecord,\n  bodySections?: Record<string, string>,\n): string {\n  const parsed = matter(normalizeInlineMaps(template));\n  // Templater scripts are for manual creation inside Obsidian only — leaked\n  // into a rendered artifact they execute on file creation and prompt the user.\n  const noTemplater = parsed.content.replace(/<!--\\s*<%\\*[\\s\\S]*?-->\\n*/g, \"\");\n  const stripped = stripGuidanceForFilled(noTemplater, bodySections);\n  const withLists = renderEachBlocks(stripped, values);\n  const body = withLists.replace(/{{([A-Za-z0-9_]+)}}/g, (_placeholder: string, name: string) => {\n    const section = bodySections?.[name];\n    if (section !== undefined) {\n      return section;\n    }\n    if (name === \"date\") {\n      const updated = values.updated;\n      return typeof updated === \"string\" ? updated : \"\";\n    }\n    const value = values[name];\n    if (Array.isArray(value)) {\n      return value.join(\", \");\n    }\n    if (value === undefined) {\n      return \"\";\n    }\n    return String(value);\n  });\n\n  return `${matter.stringify(body.trimStart(), values)}\\n`;\n}\n\n/**\n * Remove the authoring-guidance blockquote that follows a `{{placeholder}}`\n * line for every placeholder that received body content — the guidance is\n * for an author filling the section in, not for a filled artifact.\n */\nfunction stripGuidanceForFilled(body: string, bodySections?: Record<string, string>): string {\n  if (bodySections === undefined) {\n    return body;\n  }\n  let result = body;\n  for (const name of Object.keys(bodySections)) {\n    const guidanceRe = new RegExp(`({{${name}}})\\\\n\\\\n(?:>.*\\\\n?)+`);\n    result = result.replace(guidanceRe, \"$1\\n\");\n  }\n  return result;\n}\n\n/**\n * Expand `{{#each field}}…{{else}}…{{/each}}` blocks: the each branch repeats\n * per list item with `{{this}}` substituted; the else branch renders when the\n * field is missing, not a list, or empty. Runs before the plain-placeholder\n * pass so `{{this}}` never leaks into it.\n */\nfunction renderEachBlocks(body: string, values: NormalizedRecord): string {\n  const blockRe = /{{#each ([A-Za-z0-9_]+)}}([\\s\\S]*?)(?:{{else}}([\\s\\S]*?))?{{\\/each}}/g;\n  return body.replace(blockRe, (_block: string, name: string, item: string, elseBranch: string | undefined) => {\n    const value = values[name];\n    if (Array.isArray(value) && value.length > 0) {\n      return value.map((entry) => item.replace(/{{this}}/g, String(entry))).join(\"\");\n    }\n    return elseBranch ?? \"\";\n  });\n}\n\n/**\n * Canonical frontmatter order: schema declaration order first (id leads),\n * then any unknown fields in their original relative order.\n */\nexport function orderBySchema(schema: Schema, record: NormalizedRecord): NormalizedRecord {\n  const schemaNames = schema.fields.map((field) => field.name);\n  const known = new Set(schemaNames);\n  const ordered: NormalizedRecord = {};\n  for (const name of schemaNames) {\n    if (record[name] !== undefined) ordered[name] = record[name];\n  }\n  for (const name of Object.keys(record)) {\n    if (!known.has(name)) ordered[name] = record[name];\n  }\n  return ordered;\n}\n\nexport function applyDefaults(schema: Schema, template: string, input: Record<string, unknown>): NormalizedRecord {\n  const values: NormalizedRecord = { ...input };\n  const today = new Date().toISOString().slice(0, 10);\n\n  const templateDefaults = readTemplateDefaults(template);\n\n  for (const field of schema.fields) {\n    if (values[field.name] !== undefined) {\n      continue;\n    }\n    const templateDefault = templateDefaults[field.name];\n    if (templateDefault !== undefined) {\n      values[field.name] = templateDefault;\n    } else if (field.name === \"created\" || field.name === \"updated\" || field.name === \"session_date\") {\n      values[field.name] = today;\n    } else if (field.type === \"list\" || field.type === \"link_list\") {\n      values[field.name] = [];\n    }\n  }\n\n  return values;\n}\n\nfunction readTemplateDefaults(template: string): Record<string, unknown> {\n  const parsed = matter(normalizeInlineMaps(template));\n  const rawSchema = parsed.data.schema;\n  if (!isRecord(rawSchema)) {\n    return {};\n  }\n  const defaults: Record<string, unknown> = {};\n  for (const [fieldName, rawField] of Object.entries(rawSchema)) {\n    if (isRecord(rawField) && rawField.default !== undefined) {\n      defaults[fieldName] = rawField.default;\n    }\n  }\n  return defaults;\n}\n\nfunction isRecord(value: unknown): value is Record<string, unknown> {\n  return typeof value === \"object\" && value !== null && !Array.isArray(value);\n}\n","numLines":131,"startLine":1,"totalLines":131}}}
