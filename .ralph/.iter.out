{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NPo8a87LEbaW1rzKXcEYMP","type":"tool_result","content":"1\timport { afterEach, describe, expect, test } from \"bun:test\";\n2\timport { chmod, mkdir, mkdtemp, readFile, rm, writeFile } from \"node:fs/promises\";\n3\timport { tmpdir } from \"node:os\";\n4\timport { join } from \"node:path\";\n5\t\n6\tconst tempPaths: string[] = [];\n7\t\n8\tafterEach(async () => {\n9\t  await Promise.all(tempPaths.splice(0).map((path) => rm(path, { recursive: true, force: true })));\n10\t});\n11\t\n12\tdescribe(\"sync CLI\", () => {\n13\t  test(\"sync refuses (exit 1) when docs/ has a rogue folder, before embedding\", async () => {\n14\t    const fixture = await createSyncFixture(\"wiki-v2\");\n15\t    await mkdir(join(fixture.projectPath, \"docs\", \"cracking\"), { recursive: true });\n16\t    await writeFile(join(fixture.projectPath, \"docs\", \"cracking\", \"note.md\"), \"# raw\\n\");\n17\t\n18\t    const result = await runWiki([\"sync\", \"--project\", \"wiki-v2\"], fixture);\n19\t\n20\t    expect(result.exitCode).toBe(1);\n21\t    expect(result.stderr).toContain(\"not a locked category\");\n22\t    expect(result.stderr).toContain(\"refusing to sync\");\n23\t    // gate runs before qmd: no embed should have happened\n24\t    expect(await readFile(fixture.stateFile, \"utf8\").catch(() => \"\")).not.toContain(\"embed -c wiki-v2\");\n25\t  });\n26\t\n27\t  test(\"sync ensures the project collection, updates, and embeds without stdout\", async () => {\n28\t    const fixture = await createSyncFixture(\"wiki-v2\");\n29\t\n30\t    const result = await runWiki([\"sync\", \"--project\", \"wiki-v2\"], fixture);\n31\t\n32\t    expect(result.exitCode).toBe(0);\n33\t    expect(result.stdout).toBe(\"\");\n34\t    expect(result.stderr).toContain(\"synced collection wiki-v2\");\n35\t    expect(await readFile(fixture.stateFile, \"utf8\")).toBe(\n36\t      `collection list\\ncollection add ${fixture.projectPath} --name wiki-v2 --mask **/*.md\\nupdate -c wiki-v2\\nembed -c wiki-v2\\n`,\n37\t    );\n38\t  });\n39\t\n40\t  test(\"sync include-research also refreshes the research collection\", async () => {\n41\t    const fixture = await createSyncFixture(\"wiki-v2\");\n42\t\n43\t    const result = await runWiki([\"sync\", \"--project\", \"wiki-v2\", \"--include-research\"], fixture);\n44\t\n45\t    expect(result.exitCode).toBe(0);\n46\t    expect(result.stdout).toBe(\"\");\n47\t    expect(await readFile(fixture.stateFile, \"utf8\")).toBe(\n48\t      `collection list\\ncollection add ${fixture.projectPath} --name wiki-v2 --mask **/*.md\\nupdate -c wiki-v2\\nembed -c wiki-v2\\n` +\n49\t        `collection list\\ncollection add ${fixture.researchPath} --name research --mask **/*.md\\nupdate -c research\\nembed -c research\\n`,\n50\t    );\n51\t  });\n52\t\n53\t  test(\"sync skips collection add when the collection already exists\", async () => {\n54\t    const fixture = await createSyncFixture(\"wiki-v2\");\n55\t\n56\t    expect((await runWiki([\"sync\", \"--project\", \"wiki-v2\"], fixture)).exitCode).toBe(0);\n57\t    expect((await runWiki([\"sync\", \"--project\", \"wiki-v2\"], fixture)).exitCode).toBe(0);\n58\t\n59\t    expect(await readFile(fixture.stateFile, \"utf8\")).toBe(\n60\t      `collection list\\ncollection add ${fixture.projectPath} --name wiki-v2 --mask **/*.md\\nupdate -c wiki-v2\\nembed -c wiki-v2\\n` +\n61\t        \"collection list\\nupdate -c wiki-v2\\nembed -c wiki-v2\\n\",\n62\t    );\n63\t  });\n64\t\n65\t  test(\"sync passes pull and force-embed flags through to QMD\", async () => {\n66\t    const fixture = await createSyncFixture(\"wiki-v2\");\n67\t\n68\t    const result = await runWiki([\"sync\", \"--project\", \"wiki-v2\", \"--pull\", \"--force-embed\"], fixture);\n69\t\n70\t    expect(result.exitCode).toBe(0);\n71\t    expect(await readFile(fixture.stateFile, \"utf8\")).toBe(\n72\t      `collection list\\ncollection add ${fixture.projectPath} --name wiki-v2 --mask **/*.md\\nupdate --pull -c wiki-v2\\nembed -f -c wiki-v2\\n`,\n73\t    );\n74\t  });\n75\t\n76\t  test(\"sync exits 1 when project is missing and the repo isn't linked\", async () => {\n77\t    const fixture = await createSyncFixture(\"wiki-v2\");\n78\t\n79\t    await withLinkedRepo(null, async (cwd) => {\n80\t      const result = await runWiki([\"sync\"], fixture, cwd);\n81\t\n82\t      expect(result.exitCode).toBe(1);\n83\t      expect(result.stdout).toBe(\"\");\n84\t      expect(result.stderr).toContain(\"missing required field: project\");\n85\t    });\n86\t  });\n87\t\n88\t  // --- linked-repo fallback (SLICE-0052): sync resolves the project like create does ---\n89\t\n90\t  test(\"sync with a linked repo and no --project syncs the linked project\", async () => {\n91\t    const fixture = await createSyncFixture(\"wiki-v2\");\n92\t\n93\t    await withLinkedRepo(\"wiki-v2\", async (cwd) => {\n94\t      const result = await runWiki([\"sync\"], fixture, cwd);\n95\t\n96\t      expect(result.exitCode).toBe(0);\n97\t      expect(result.stderr).toContain(\"synced collection wiki-v2\");\n98\t    });\n99\t  });\n100\t\n101\t  test(\"sync --project overrides the linked repo\", async () => {\n102\t    const fixture = await createSyncFixture(\"other-proj\");\n103\t\n104\t    await withLinkedRepo(\"wiki-v2\", async (cwd) => {\n105\t      const result = await runWiki([\"sync\", \"--project\", \"other-proj\"], fixture, cwd);\n106\t\n107\t      expect(result.exitCode).toBe(0);\n108\t      expect(result.stderr).toContain(\"synced collection other-proj\");\n109\t    });\n110\t  });\n111\t\n112\t  test(\"sync exits 10 and surfaces qmd stderr when qmd fails\", async () => {\n113\t    const fixture = await createSyncFixture(\"wiki-v2\", { failUpdate: true });\n114\t\n115\t    const result = await runWiki([\"sync\", \"--project\", \"wiki-v2\"], fixture);\n116\t\n117\t    expect(result.exitCode).toBe(10);\n118\t    expect(result.stdout).toBe(\"\");\n119\t    expect(result.stderr).toContain(\"fake qmd update failed\");\n120\t  });\n121\t});\n122\t\n123\ttype SyncFixture = {\n124\t  vaultRoot: string;\n125\t  projectPath: string;\n126\t  researchPath: string;\n127\t  stateFile: string;\n128\t  env: Record<string, string>;\n129\t};\n130\t\n131\ttype SyncFixtureOptions = {\n132\t  failUpdate?: boolean;\n133\t};\n134\t\n135\ttype CommandResult = {\n136\t  exitCode: number;\n137\t  stdout: string;\n138\t  stderr: string;\n139\t};\n140\t\n141\tconst repoRoot = import.meta.dir.replace(/\\/tests$/, \"\");\n142\t\n143\t/** Create a temp repo dir linked to `project` via a pointer block (or unlinked when null). */\n144\tasync function withLinkedRepo(project: string | null, fn: (cwd: string) => Promise<void>): Promise<void> {\n145\t  const repo = await mkdtemp(join(tmpdir(), \"wiki-sync-repo-\"));\n146\t  tempPaths.push(repo);\n147\t  if (project !== null) {\n148\t    await writeFile(join(repo, \"AGENTS.md\"), `<!-- wiki:begin v2 project=${project} -->\\n<!-- wiki:end -->\\n`);\n149\t  }\n150\t  await fn(repo);\n151\t}\n152\t\n153\tasync function runWiki(args: string[], fixture: SyncFixture, cwd: string = repoRoot): Promise<CommandResult> {\n154\t  const proc = Bun.spawn([\"bun\", join(repoRoot, \"src\", \"cli.ts\"), ...args], {\n155\t    cwd,\n156\t    env: { ...process.env, KNOWLEDGE_VAULT_ROOT: fixture.vaultRoot, ...fixture.env },\n157\t    stdout: \"pipe\",\n158\t    stderr: \"pipe\",\n159\t  });\n160\t  const [stdout, stderr, exitCode] = await Promise.all([\n161\t    new Response(proc.stdout).text(),\n162\t    new Response(proc.stderr).text(),\n163\t    proc.exited,\n164\t  ]);\n165\t  return { exitCode, stdout, stderr };\n166\t}\n167\t\n168\tasync function createSyncFixture(project: string, options: SyncFixtureOptions = {}): Promise<SyncFixture> {\n169\t  const root = await mkdtemp(join(tmpdir(), \"wiki-sync-\"));\n170\t  tempPaths.push(root);\n171\t  const vaultRoot = join(root, \"vault\");\n172\t  const projectPath = join(vaultRoot, \"projects\", project);\n173\t  await mkdir(join(projectPath, \"prds\"), { recursive: true });\n174\t  await mkdir(join(projectPath, \"slices\"));\n175\t  await mkdir(join(projectPath, \"adrs\"));\n176\t  await mkdir(join(projectPath, \"handoffs\"));\n177\t  await mkdir(join(projectPath, \"docs\"));\n178\t  const researchPath = join(root, \"research\");\n179\t  await mkdir(researchPath);\n180\t  await writeFile(\n181\t    join(projectPath, \"_project.md\"),\n182\t    `---\\nrepo: /tmp/repo\\ntest_command: bun test\\nresearch_path: ${researchPath}\\n---\\n`,\n183\t  );\n184\t\n185\t  const stateFile = join(root, \"qmd-state.log\");\n186\t  const registeredFile = join(root, \"qmd-registered.txt\");\n187\t  const qmdCommand = join(root, \"fake-qmd\");\n188\t  await writeFile(\n189\t    qmdCommand,\n190\t    `#!/usr/bin/env bash\n191\tset -euo pipefail\n192\techo \"$@\" >> \"$STATE_FILE\"\n193\tcase \"\\${1:-}\" in\n194\t  collection)\n195\t    case \"\\${2:-}\" in\n196\t      list)\n197\t        if [ -f \"$REGISTERED_FILE\" ]; then\n198\t          cat \"$REGISTERED_FILE\"\n199\t        fi\n200\t        ;;\n201\t      add)\n202\t        # extract --name value from args\n203\t        shift 2\n204\t        while [ $# -gt 0 ]; do\n205\t          if [ \"$1\" = \"--name\" ]; then\n206\t            # mirror real qmd's \"collection list\" shape: \"name (qmd://name/)\"\n207\t            echo \"$2 (qmd://$2/)\" >> \"$REGISTERED_FILE\"\n208\t            break\n209\t          fi\n210\t          shift\n211\t        done\n212\t        ;;\n213\t    esac\n214\t    ;;\n215\t  update)\n216\t    if [ \"\\${FAIL_UPDATE:-}\" = \"1\" ]; then\n217\t      echo \"fake qmd update failed\" >&2\n218\t      exit 7\n219\t    fi\n220\t    ;;\n221\tesac\n222\t`,\n223\t  );\n224\t  await chmod(qmdCommand, 0o755);\n225\t\n226\t  return {\n227\t    vaultRoot,\n228\t    projectPath,\n229\t    researchPath,\n230\t    stateFile,\n231\t    env: {\n232\t      QMD_COMMAND: qmdCommand,\n233\t      STATE_FILE: stateFile,\n234\t      REGISTERED_FILE: registeredFile,\n235\t      FAIL_UPDATE: options.failUpdate === true ? \"1\" : \"0\",\n236\t    },\n237\t  };\n238\t}\n239\t"}]},"parent_tool_use_id":null,"session_id":"28ab8cbe-87eb-42f8-8aa3-f40cdb29823c","uuid":"9a794fc8-acc9-44c8-a3e7-1cb0434fa9f9","timestamp":"2026-06-23T16:39:26.806Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/tothemoon/Dev/code-forge/wiki/tests/cli-sync.test.ts","content":"import { afterEach, describe, expect, test } from \"bun:test\";\nimport { chmod, mkdir, mkdtemp, readFile, rm, writeFile } from \"node:fs/promises\";\nimport { tmpdir } from \"node:os\";\nimport { join } from \"node:path\";\n\nconst tempPaths: string[] = [];\n\nafterEach(async () => {\n  await Promise.all(tempPaths.splice(0).map((path) => rm(path, { recursive: true, force: true })));\n});\n\ndescribe(\"sync CLI\", () => {\n  test(\"sync refuses (exit 1) when docs/ has a rogue folder, before embedding\", async () => {\n    const fixture = await createSyncFixture(\"wiki-v2\");\n    await mkdir(join(fixture.projectPath, \"docs\", \"cracking\"), { recursive: true });\n    await writeFile(join(fixture.projectPath, \"docs\", \"cracking\", \"note.md\"), \"# raw\\n\");\n\n    const result = await runWiki([\"sync\", \"--project\", \"wiki-v2\"], fixture);\n\n    expect(result.exitCode).toBe(1);\n    expect(result.stderr).toContain(\"not a locked category\");\n    expect(result.stderr).toContain(\"refusing to sync\");\n    // gate runs before qmd: no embed should have happened\n    expect(await readFile(fixture.stateFile, \"utf8\").catch(() => \"\")).not.toContain(\"embed -c wiki-v2\");\n  });\n\n  test(\"sync ensures the project collection, updates, and embeds without stdout\", async () => {\n    const fixture = await createSyncFixture(\"wiki-v2\");\n\n    const result = await runWiki([\"sync\", \"--project\", \"wiki-v2\"], fixture);\n\n    expect(result.exitCode).toBe(0);\n    expect(result.stdout).toBe(\"\");\n    expect(result.stderr).toContain(\"synced collection wiki-v2\");\n    expect(await readFile(fixture.stateFile, \"utf8\")).toBe(\n      `collection list\\ncollection add ${fixture.projectPath} --name wiki-v2 --mask **/*.md\\nupdate -c wiki-v2\\nembed -c wiki-v2\\n`,\n    );\n  });\n\n  test(\"sync include-research also refreshes the research collection\", async () => {\n    const fixture = await createSyncFixture(\"wiki-v2\");\n\n    const result = await runWiki([\"sync\", \"--project\", \"wiki-v2\", \"--include-research\"], fixture);\n\n    expect(result.exitCode).toBe(0);\n    expect(result.stdout).toBe(\"\");\n    expect(await readFile(fixture.stateFile, \"utf8\")).toBe(\n      `collection list\\ncollection add ${fixture.projectPath} --name wiki-v2 --mask **/*.md\\nupdate -c wiki-v2\\nembed -c wiki-v2\\n` +\n        `collection list\\ncollection add ${fixture.researchPath} --name research --mask **/*.md\\nupdate -c research\\nembed -c research\\n`,\n    );\n  });\n\n  test(\"sync skips collection add when the collection already exists\", async () => {\n    const fixture = await createSyncFixture(\"wiki-v2\");\n\n    expect((await runWiki([\"sync\", \"--project\", \"wiki-v2\"], fixture)).exitCode).toBe(0);\n    expect((await runWiki([\"sync\", \"--project\", \"wiki-v2\"], fixture)).exitCode).toBe(0);\n\n    expect(await readFile(fixture.stateFile, \"utf8\")).toBe(\n      `collection list\\ncollection add ${fixture.projectPath} --name wiki-v2 --mask **/*.md\\nupdate -c wiki-v2\\nembed -c wiki-v2\\n` +\n        \"collection list\\nupdate -c wiki-v2\\nembed -c wiki-v2\\n\",\n    );\n  });\n\n  test(\"sync passes pull and force-embed flags through to QMD\", async () => {\n    const fixture = await createSyncFixture(\"wiki-v2\");\n\n    const result = await runWiki([\"sync\", \"--project\", \"wiki-v2\", \"--pull\", \"--force-embed\"], fixture);\n\n    expect(result.exitCode).toBe(0);\n    expect(await readFile(fixture.stateFile, \"utf8\")).toBe(\n      `collection list\\ncollection add ${fixture.projectPath} --name wiki-v2 --mask **/*.md\\nupdate --pull -c wiki-v2\\nembed -f -c wiki-v2\\n`,\n    );\n  });\n\n  test(\"sync exits 1 when project is missing and the repo isn't linked\", async () => {\n    const fixture = await createSyncFixture(\"wiki-v2\");\n\n    await withLinkedRepo(null, async (cwd) => {\n      const result = await runWiki([\"sync\"], fixture, cwd);\n\n      expect(result.exitCode).toBe(1);\n      expect(result.stdout).toBe(\"\");\n      expect(result.stderr).toContain(\"missing required field: project\");\n    });\n  });\n\n  // --- linked-repo fallback (SLICE-0052): sync resolves the project like create does ---\n\n  test(\"sync with a linked repo and no --project syncs the linked project\", async () => {\n    const fixture = await createSyncFixture(\"wiki-v2\");\n\n    await withLinkedRepo(\"wiki-v2\", async (cwd) => {\n      const result = await runWiki([\"sync\"], fixture, cwd);\n\n      expect(result.exitCode).toBe(0);\n      expect(result.stderr).toContain(\"synced collection wiki-v2\");\n    });\n  });\n\n  test(\"sync --project overrides the linked repo\", async () => {\n    const fixture = await createSyncFixture(\"other-proj\");\n\n    await withLinkedRepo(\"wiki-v2\", async (cwd) => {\n      const result = await runWiki([\"sync\", \"--project\", \"other-proj\"], fixture, cwd);\n\n      expect(result.exitCode).toBe(0);\n      expect(result.stderr).toContain(\"synced collection other-proj\");\n    });\n  });\n\n  test(\"sync exits 10 and surfaces qmd stderr when qmd fails\", async () => {\n    const fixture = await createSyncFixture(\"wiki-v2\", { failUpdate: true });\n\n    const result = await runWiki([\"sync\", \"--project\", \"wiki-v2\"], fixture);\n\n    expect(result.exitCode).toBe(10);\n    expect(result.stdout).toBe(\"\");\n    expect(result.stderr).toContain(\"fake qmd update failed\");\n  });\n});\n\ntype SyncFixture = {\n  vaultRoot: string;\n  projectPath: string;\n  researchPath: string;\n  stateFile: string;\n  env: Record<string, string>;\n};\n\ntype SyncFixtureOptions = {\n  failUpdate?: boolean;\n};\n\ntype CommandResult = {\n  exitCode: number;\n  stdout: string;\n  stderr: string;\n};\n\nconst repoRoot = import.meta.dir.replace(/\\/tests$/, \"\");\n\n/** Create a temp repo dir linked to `project` via a pointer block (or unlinked when null). */\nasync function withLinkedRepo(project: string | null, fn: (cwd: string) => Promise<void>): Promise<void> {\n  const repo = await mkdtemp(join(tmpdir(), \"wiki-sync-repo-\"));\n  tempPaths.push(repo);\n  if (project !== null) {\n    await writeFile(join(repo, \"AGENTS.md\"), `<!-- wiki:begin v2 project=${project} -->\\n<!-- wiki:end -->\\n`);\n  }\n  await fn(repo);\n}\n\nasync function runWiki(args: string[], fixture: SyncFixture, cwd: string = repoRoot): Promise<CommandResult> {\n  const proc = Bun.spawn([\"bun\", join(repoRoot, \"src\", \"cli.ts\"), ...args], {\n    cwd,\n    env: { ...process.env, KNOWLEDGE_VAULT_ROOT: fixture.vaultRoot, ...fixture.env },\n    stdout: \"pipe\",\n    stderr: \"pipe\",\n  });\n  const [stdout, stderr, exitCode] = await Promise.all([\n    new Response(proc.stdout).text(),\n    new Response(proc.stderr).text(),\n    proc.exited,\n  ]);\n  return { exitCode, stdout, stderr };\n}\n\nasync function createSyncFixture(project: string, options: SyncFixtureOptions = {}): Promise<SyncFixture> {\n  const root = await mkdtemp(join(tmpdir(), \"wiki-sync-\"));\n  tempPaths.push(root);\n  const vaultRoot = join(root, \"vault\");\n  const projectPath = join(vaultRoot, \"projects\", project);\n  await mkdir(join(projectPath, \"prds\"), { recursive: true });\n  await mkdir(join(projectPath, \"slices\"));\n  await mkdir(join(projectPath, \"adrs\"));\n  await mkdir(join(projectPath, \"handoffs\"));\n  await mkdir(join(projectPath, \"docs\"));\n  const researchPath = join(root, \"research\");\n  await mkdir(researchPath);\n  await writeFile(\n    join(projectPath, \"_project.md\"),\n    `---\\nrepo: /tmp/repo\\ntest_command: bun test\\nresearch_path: ${researchPath}\\n---\\n`,\n  );\n\n  const stateFile = join(root, \"qmd-state.log\");\n  const registeredFile = join(root, \"qmd-registered.txt\");\n  const qmdCommand = join(root, \"fake-qmd\");\n  await writeFile(\n    qmdCommand,\n    `#!/usr/bin/env bash\nset -euo pipefail\necho \"$@\" >> \"$STATE_FILE\"\ncase \"\\${1:-}\" in\n  collection)\n    case \"\\${2:-}\" in\n      list)\n        if [ -f \"$REGISTERED_FILE\" ]; then\n          cat \"$REGISTERED_FILE\"\n        fi\n        ;;\n      add)\n        # extract --name value from args\n        shift 2\n        while [ $# -gt 0 ]; do\n          if [ \"$1\" = \"--name\" ]; then\n            # mirror real qmd's \"collection list\" shape: \"name (qmd://name/)\"\n            echo \"$2 (qmd://$2/)\" >> \"$REGISTERED_FILE\"\n            break\n          fi\n          shift\n        done\n        ;;\n    esac\n    ;;\n  update)\n    if [ \"\\${FAIL_UPDATE:-}\" = \"1\" ]; then\n      echo \"fake qmd update failed\" >&2\n      exit 7\n    fi\n    ;;\nesac\n`,\n  );\n  await chmod(qmdCommand, 0o755);\n\n  return {\n    vaultRoot,\n    projectPath,\n    researchPath,\n    stateFile,\n    env: {\n      QMD_COMMAND: qmdCommand,\n      STATE_FILE: stateFile,\n      REGISTERED_FILE: registeredFile,\n      FAIL_UPDATE: options.failUpdate === true ? \"1\" : \"0\",\n    },\n  };\n}\n","numLines":239,"startLine":1,"totalLines":239}}}
